# 복사: cp .env.example .env  (또는 셸 export / IDE Run Configuration)
# .env 는 git 에 올리지 마세요.

# --- Gmail SMTP 예시 ---
# 1) Google 계정 2단계 인증 켜기
# 2) https://myaccount.google.com/apppasswords 에서 앱 비밀번호 생성
# 3) 아래 값 채우기 (비밀번호 16자, 공백 제거)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_account@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_FROM=your_account@gmail.com

# 서버
SERVER_PORT=8080

# DB
# 비워두면 로컬 데모용 메모리 H2 DB를 사용합니다.
# 실행할 때마다 데이터가 초기화되는 것이 싫으면 아래처럼 파일 DB를 지정하세요.
# DB_URL=jdbc:h2:file:./data/myeongrang;MODE=PostgreSQL;DB_CLOSE_DELAY=-1

# 카카오 REST API 키 (펀딩 사진 없을 때 위치 기반 정적 지도 이미지)
# Developers > 앱 키 > REST API 키 (JavaScript 키와 다름)
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# Gemini AI API 키 (AI 넛지, 노쇼 리스크, 후기 요약, 성사율 예측)
# Google AI Studio에서 발급. 비워두면 기존 로컬 규칙 기반 백업 분석으로 동작합니다.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
